# Root template. Copy into pepta-backend/.env for local API work.

NODE_ENV=development
PORT=8080
MONGODB_URI=mongodb://127.0.0.1:27017/pepta
JWT_SECRET=replace_with_a_random_secret_at_least_64_characters
JWT_EXPIRES_IN=30d
GOOGLE_CLIENT_ID=your-google-web-client-id.apps.googleusercontent.com
FRONTEND_ORIGIN=http://localhost:8081

# Optional native Apple Sign-In. If absent, POST /auth/apple returns 503.
APPLE_TEAM_ID=YOUR_TEAM_ID
APPLE_CLIENT_ID=ai.boltzman.pepta
APPLE_KEY_ID=YOUR_KEY_ID
APPLE_PRIVATE_KEY_BASE64=base64_encoded_pem_private_key

# S3 progress photo and meal-scan image storage. Required in production.
AWS_REGION=us-west-2
AWS_S3_BUCKET_NAME=pepta-private-media
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key

# AI prose and image analysis. Deterministic numbers never come from AI.
OPENAI_API_KEY=your_openai_api_key

# RevenueCat webhook verification.
REVENUECAT_WEBHOOK_SECRET=your_revenuecat_webhook_secret

# Scheduled jobs.
SCHEDULER_TIMEZONE=America/New_York
WEEKLY_RETENTION_CRON=0 8 * * 1
MEDICATION_LEVEL_CRON=0 3 * * *

# Frontend
EXPO_PUBLIC_API_BASE_URL=http://localhost:8080
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your-google-web-client-id.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=your-google-ios-client-id.apps.googleusercontent.com
EXPO_PUBLIC_REVENUECAT_IOS_API_KEY=appl_your_revenuecat_key
