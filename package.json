{
  "name": "pepta",
  "version": "0.1.0",
  "private": true,
  "description": "Pepta monorepo",
  "workspaces": [
    "shared",
    "pepta-backend",
    "pepta-frontend"
  ],
  "scripts": {
    "predev": "npm run build -w @pepta/shared",
    "dev": "concurrently -n shared,backend,frontend -c cyan,green,magenta \"npm run dev -w @pepta/shared\" \"npm run dev -w @pepta/backend\" \"npm run dev -w @pepta/frontend\"",
    "build": "npm run build -ws --if-present",
    "prelint": "npm run build -w @pepta/shared",
    "lint": "eslint .",
    "pretypecheck": "npm run build -w @pepta/shared",
    "typecheck": "npm run typecheck -ws --if-present",
    "test": "npm run test -ws --if-present",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.0",
    "concurrently": "^9.1.2",
    "eslint": "^9.25.0",
    "globals": "^16.0.0",
    "prettier": "^3.5.3",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.30.1"
  }
}
